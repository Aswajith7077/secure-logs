MODEL_NAME=bert-base-uncased
MAX_LEN=64
LR=2e-5

DATA_PATH=data/HDFS/2k-structured.csv
LABEL_PATH=data/HDFS/anomaly_label.csv
SAVE_DIR=ai-models/2k-dataset

# CPU settings (small dataset, quick iteration)
CPU_BATCH_SIZE=16
CPU_PRETRAIN_EPOCHS=1
CPU_FINETUNE_EPOCHS=1
CPU_PRETRAIN_PAIRS=200

# GPU settings (faster, more epochs)
GPU_BATCH_SIZE=32
GPU_PRETRAIN_EPOCHS=5
GPU_FINETUNE_EPOCHS=5
GPU_PRETRAIN_PAIRS=2000