MODEL_NAME=bert-base-uncased
MAX_LEN=128
LR=1e-5

DATA_PATH=data/HDFS/full-structured.csv
LABEL_PATH=data/HDFS/anomaly_label.csv
SAVE_DIR=ai-models/full-dataset

PREDICT_DIR=result/full

# CPU settings (very heavy dataset — minimal config for debugging only)
CPU_BATCH_SIZE=8
CPU_PRETRAIN_EPOCHS=1
CPU_FINETUNE_EPOCHS=1
CPU_PRETRAIN_PAIRS=200

# GPU settings (intended runtime for full dataset)
GPU_BATCH_SIZE=128
GPU_PRETRAIN_EPOCHS=20
GPU_FINETUNE_EPOCHS=20
GPU_PRETRAIN_PAIRS=50000